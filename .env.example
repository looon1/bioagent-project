# BioAgent Configuration Example
# Copy this file to .env and fill in your values

# LLM Configuration
# Choose one of the following providers:

# Option 1: Zhipu AI (GLM models)
MODEL_ID=glm-4.7
ZHIPU_API_KEY=your_zhipu_api_key_here

# Option 2: Anthropic Claude
# MODEL_ID=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 3: OpenAI
# MODEL_ID=gpt-4
# OPENAI_API_KEY=your_openai_api_key_here

# Option 4: Custom endpoint (OpenAI-compatible)
# MODEL_ID=custom-model
# BIOAGENT_API_KEY=your_api_key_here
# BIOAGENT_BASE_URL=https://your-custom-endpoint.com/v1

# Paths
BIOAGENT_LOGS_PATH=./logs
BIOAGENT_DATA_PATH=./data

# Agent Settings
BIOAGENT_MAX_TOKENS=4096
BIOAGENT_TEMPERATURE=0.7
BIOAGENT_MAX_TOOL_ITERATIONS=10
BIOAGENT_MAX_MESSAGE_HISTORY=20

# Observability
BIOAGENT_ENABLE_METRICS=true
BIOAGENT_ENABLE_COST_TRACKING=true
BIOAGENT_LOG_LEVEL=INFO
